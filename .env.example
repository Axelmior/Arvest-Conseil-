# ── Resend (email provider) ───────────────────────────────────────────────────
# Créer un compte sur https://resend.com et générer une clé API.
# En dev, laissez vide : les appels /api/send-email échoueront silencieusement.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Adresse expéditeur vérifiée dans Resend (domaine vérifié requis en production).
# En mode test Resend, utilisez : onboarding@resend.dev
RESEND_FROM=Arvest Pilot <noreply@votre-domaine.fr>

# Email de réponse (reply-to) affiché dans les emails envoyés.
RESEND_REPLY=arvest-conseil@outlook.com

# URL de l'application (utilisée dans les liens des emails).
APP_URL=https://arvest-pilot.vercel.app

# ── Configuration dans Vercel ────────────────────────────────────────────────
# Dashboard Vercel → Settings → Environment Variables → ajouter chaque variable ci-dessus.
# Ces variables ne sont JAMAIS exposées côté client (uniquement dans /api/*).
